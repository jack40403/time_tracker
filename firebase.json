  "hosting": {
    "site": "metimegoalgoal",
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "!/**/*.apk",
        "destination": "/index.html"
